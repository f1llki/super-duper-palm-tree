#include <iostream>
#include <string>
#include <iomanip>
using namespace std;

/**
 * Класс Book - моделирует книгу в книжном магазине
 * Поля: название, автор, цена, количество экземпляров
 */
class Book {
private:
    string title;       // название книги
    string author;      // автор книги
    double price;       // цена книги
    int quantity;       // количество экземпляров в наличии

public:
    /**
     * Конструктор по умолчанию
     * Инициализирует поля начальными значениями
     */
    Book() {
        title = "Не указано";
        author = "Не указан";
        price = 0.0;
        quantity = 0;
        cout << "Создан объект Book (конструктор по умолчанию)" << endl;
    }
    
    /**
     * Конструктор с параметрами
     * Принимает значения для всех полей
     */
    Book(string t, string a, double p, int q) {
        title = t;
        author = a;
        setPrice(p);      // используем сеттер с валидацией
        setQuantity(q);   // используем сеттер с валидацией
        cout << "Создан объект Book: \"" << title << "\" (конструктор с параметрами)" << endl;
    }
    
    /**
     * Деструктор
     * Выводит сообщение об уничтожении объекта
     */
    ~Book() {
        cout << "Уничтожен объект Book: \"" << title << "\"" << endl;
    }
    
    // ========== Геттеры ==========
    
    string getTitle() {
        return title;
    }
    
    string getAuthor() {
        return author;
    }
    
    double getPrice() {
        return price;
    }
    
    int getQuantity() {
        return quantity;
    }
    
    // ========== Сеттеры с валидацией ==========
    
    /**
     * Установка цены с валидацией
     * Цена не может быть отрицательной
     */
    void setPrice(double p) {
        if (p >= 0) {
            price = p;
        } else {
            cout << "Ошибка: цена не может быть отрицательной. Установлено значение 0" << endl;
            price = 0;
        }
    }
    
    /**
     * Установка количества с валидацией
     * Количество не может быть отрицательным
     */
    void setQuantity(int q) {
        if (q >= 0) {
            quantity = q;
        } else {
            cout << "Ошибка: количество не может быть отрицательным. Установлено значение 0" << endl;
            quantity = 0;
        }
    }
    
    // ========== Методы поведения ==========
    
    /**
     * Продажа одного экземпляра книги
     * Уменьшает количество на 1, если есть в наличии
     */
    void sellOneCopy() {
        if (quantity > 0) {
            quantity--;
            cout << "Продана книга \"" << title << "\". Осталось экземпляров: " << quantity << endl;
        } else {
            cout << "Ошибка: книга \"" << title << "\" отсутствует в наличии" << endl;
        }
    }
    
    /**
     * Поступление партии книг
     * Увеличивает количество на заданное значение
     */
    void addStock(int count) {
        if (count > 0) {
            quantity += count;
            cout << "Поступило " << count << " экземпляров книги \"" << title << "\". Теперь в наличии: " << quantity << endl;
        } else {
            cout << "Ошибка: количество поступления должно быть положительным" << endl;
        }
    }
    
    /**
     * Применение скидки к цене
     * discountPercent - процент скидки (от 0 до 100)
     */
    void applyDiscount(double discountPercent) {
        if (discountPercent >= 0 && discountPercent <= 100) {
            double discountAmount = price * (discountPercent / 100);
            price -= discountAmount;
            cout << "Применена скидка " << discountPercent << "%. Новая цена: " << fixed << setprecision(2) << price << " руб." << endl;
        } else {
            cout << "Ошибка: процент скидки должен быть от 0 до 100" << endl;
        }
    }
    
    /**
     * Вывод полной информации о книге
     */
    void printInfo() {
        cout << "Название:  " << title << endl;
        cout << "Автор:     " << author << endl;
        cout << "Цена:      " << fixed << setprecision(2) << price << " руб." << endl;
        cout << "В наличии: " << quantity << " экз." << endl;
    }
};

int main() {
    setlocale(LC_ALL, "Russian");
    
    cout << "book\n" << endl;
    
    // 1. Создание объектов с помощью разных конструкторов
    cout << "Создание объектов" << endl;
    Book book1;                           // конструктор по умолчанию
    Book book2("Мастер и Маргарита", "Михаил Булгаков", 650.50, 15);  // конструктор с параметрами
    cout << endl;
    
    // 2. Вывод информации о книгах
    cout << "Информация о книгах" << endl;
    book1.printInfo();
    book2.printInfo();
    cout << endl;
    
    cout << "Демонстрация геттеров" << endl;
    cout << "Название второй книги: " << book2.getTitle() << endl;
    cout << "Автор второй книги: " << book2.getAuthor() << endl;
    cout << "Цена второй книги: " << fixed << setprecision(2) << book2.getPrice() << " руб." << endl;
    cout << "Количество второй книги: " << book2.getQuantity() << " экз." << endl;
    cout << endl;
    
    cout << "Демонстрация сеттеров с валидацией" << endl;
    cout << "Попытка установить отрицательную цену (-100):" << endl;
    book1.setPrice(-100);
    cout << "Попытка установить отрицательное количество (-5):" << endl;
    book1.setQuantity(-5);
    cout << "Установка корректных значений:" << endl;
    book1.setPrice(499.99);
    book1.setQuantity(10);
    book1.printInfo();
    cout << endl;
    
    cout << "Демонстрация методов поведения" << endl;
    
    cout << "Продажа книги:" << endl;
    book2.sellOneCopy();
    book2.printInfo();
    
    cout << "\nПоступление партии:" << endl;
    book2.addStock(5);
    book2.printInfo();
    
    cout << "\nПрименение скидки:" << endl;
    book2.applyDiscount(15);
    book2.printInfo();
    
    cout << "Демонстрация обработки некорректных операций" << endl;
    
    // Создаем книгу с нулевым количеством
    Book book3("Сказки", "Александр Пушкин", 350.00, 0);
    book3.printInfo();
    
    cout << "\nПопытка продать книгу, которой нет в наличии:" << endl;
    book3.sellOneCopy();
    
    // Попытка применить некорректную скидку
    cout << "\nПопытка применить скидку 150%:" << endl;
    book2.applyDiscount(150);
    
    cout << "\nПопытка добавить отрицательное количество:" << endl;
    book2.addStock(-10);
    
    cout << "\nfinish" << endl;
    
    return 0;
}
